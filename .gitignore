# ─────────────────────────────────────────────────────────────
# Logs, caches, misc
# ─────────────────────────────────────────────────────────────
*.log
.cache/
coverage/
.coverage
tmp/
temp/

# Runtime audit log + its checkpoint/anchor side files — generated WHEN THE APP
# RUNS, not source. The real records are never committed (they'd be demo/runtime
# artifacts in the repo); tests use throwaway logs and demo runs regenerate them
# locally. The glob also covers audit_log.csv.checkpoint / .anchor / .tmp.
audit_log.csv*

# Runtime CocoShaMem store — memories WRITTEN at run time. The committed copy is the
# seed (cocoshamem.seed.json); the live store cocoshamem.json is regenerated from it
# and appended to at runtime, so it is never committed (no runtime artifact in the repo).
cocoshamem.json
cocoshamem.json.tmp

