# Copy this file to `.env` (which is gitignored) and fill in YOUR OWN values locally.
# NEVER put real keys here — this file is committed and public.

# --- LLMs (open-weight, OpenAI-compatible) ------------------------------------
# Per-component routing: each role reads its own <COMPONENT>_LLM_* block first, and
# falls back to the generic LLM_* block below. So you can run a fast model for tagging
# and a clever one for the Judge — no code change, just env.

# Classifier — fast, cheap tagging
CLASSIFIER_LLM_BASE_URL=https://api.mistral.ai/v1
CLASSIFIER_LLM_MODEL=mistral-small-latest
CLASSIFIER_LLM_API_KEY=your-mistral-key-here

# Judge — clever read/write decisions
JUDGE_LLM_BASE_URL=https://api.mor.org/api/v1
JUDGE_LLM_MODEL=glm-5.2
JUDGE_LLM_API_KEY=your-mor-key-here

# Generic fallback (any component without its own block above)
LLM_BASE_URL=https://api.mistral.ai/v1
LLM_MODEL=mistral-small-latest
LLM_API_KEY=your-key-here

# Other providers (not used by the current pipeline)
ANTHROPIC_API_KEY=your-key-here
OPENAI_API_KEY=your-key-here

# Sponsor / other services
# FETCHAI_API_KEY=your-key-here

# Web3 (if needed) — USE A FRESH, EMPTY, THROWAWAY WALLET. Never a real key.
# WALLET_PRIVATE_KEY=do-not-put-a-real-key-here
